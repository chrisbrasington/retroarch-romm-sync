# Copy this to .env and fill in your real values. .env is gitignored -
# config.yaml/config.example.yaml intentionally hold no secrets.

# RomM > Settings > API tokens > new client token ("rmm_..." prefix).
ROMM_API_TOKEN=rmm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SSH passwords for devices configured with `auth: password` and a matching
# `password_env` in config.yaml. Only needed for stock-RetroArch devices
# (hakchi2-ce devices use auth: none/publickey instead - no password).
RG34XX_SSH_PASSWORD=root
MIYOO_SSH_PASSWORD=onion
